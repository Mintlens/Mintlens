{
  "name": "mintlens",
  "private": true,
  "version": "0.0.0",
  "description": "LLM cost tracking & governance platform for AI builders",
  "keywords": ["llm", "ai", "finops", "cost-tracking", "observability", "saas"],
  "license": "Apache-2.0",
  "homepage": "https://mintlens.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/mintlens/mintlens.git"
  },
  "bugs": {
    "url": "https://github.com/mintlens/mintlens/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml,yml}\" --ignore-path .gitignore",
    "db:generate": "turbo run db:generate --filter=api",
    "db:migrate": "turbo run db:migrate --filter=api",
    "db:studio": "turbo run db:studio --filter=api",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=@mintlens/sdk-ts --filter=@mintlens/sdk-python && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@types/node": "^22.0.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.6.2"
  }
}
