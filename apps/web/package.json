{
  "name": "@mintlens/web",
  "version": "0.1.0",
  "private": true,
  "description": "Mintlens dashboard — Next.js 15",
  "scripts": {
    "build": "next build",
    "dev": "next dev --port 3000",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
