# ============================================================
# Mintlens — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env or .env.local to version control
# ============================================================

# ── Application ─────────────────────────────────────────────
NODE_ENV=development

# ── API ─────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
LOG_LEVEL=debug

# ── Database (PostgreSQL) ────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://mintlens:changeme@localhost:5432/mintlens_dev

# Separate connection for migrations (bypasses RLS)
DATABASE_MIGRATION_URL=postgresql://mintlens_admin:changeme@localhost:5432/mintlens_dev

POSTGRES_USER=mintlens
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mintlens_dev

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://:changeme@localhost:6379
REDIS_PASSWORD=changeme

# ── Auth / Security ──────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
# Salt for API key hashing — Generate with: openssl rand -base64 32
API_KEY_SALT=your-api-key-salt-change-in-production

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@mintlens.io
FROM_NAME=Mintlens

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Integrations (optional) ─────────────────────────────────
# Slack webhook for budget alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
