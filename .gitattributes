# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Force LF for source files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.sh    text eol=lf
*.py    text eol=lf

# Binary files — no processing
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.svg   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
